{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aep.dev/schemas/aep-core-events.schema.json",
  "title": "AEP Core Event Types v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_types"
  ],
  "properties": {
    "event_types": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "task.created",
          "task.updated",
          "task.completed",
          "task.failed",
          "tool.called",
          "tool.result",
          "memory.read",
          "memory.write",
          "handoff.started",
          "handoff.completed",
          "policy.blocked",
          "error.raised"
        ]
      },
      "minItems": 12,
      "maxItems": 12
    }
  }
}
